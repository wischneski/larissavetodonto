Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve arquivos existentes (arquivos ou diretórios)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Fallback para index.html (Single Page App)
  RewriteRule ^ index.html [L]
</IfModule>

# Cache agressivo para assets estáticos (1 ano)
# Assets do Vite têm hash no nome, então cache longo é seguro
<IfModule mod_expires.c>
  ExpiresActive On
  # HTML - sem cache (pode mudar)
  ExpiresByType text/html "access plus 0 seconds"
  # JS e CSS - 1 ano (hash no nome do arquivo)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  # Imagens - 1 ano
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  # Fontes - 1 ano
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
</IfModule>

# Cache-Control headers para assets com hash
<IfModule mod_headers.c>
  # Assets JS/CSS com hash - immutable
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Imagens - cache longo
  <FilesMatch "\.(webp|png|jpg|jpeg|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000"
  </FilesMatch>
  # HTML - não cachear
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
  # Segurança
  Header set X-Content-Type-Options "nosniff"
</IfModule>

# Compressão GZIP
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
